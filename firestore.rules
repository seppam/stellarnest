rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Profile Rules
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Magic Claims Rules
    match /claims/{claimDocId} {
      // Allow anyone to fetch a single claim by its document ID (for Magic Link claim flow)
      allow get: if true;
      
      // Only the sender can list/query their sent claims
      allow list: if request.auth != null && resource.data.senderUid == request.auth.uid;
      
      // Only authenticated users can create a claim, and they must be the sender
      allow create: if request.auth != null && request.resource.data.senderUid == request.auth.uid;
      
      // Allow updates (claiming) if the claim is currently pending and not expired
      allow update: if resource.data.status == 'pending' 
        && request.resource.data.status == 'claimed'
        && (resource.data.expiresAt > request.time);
    }
    
    // Transactions Rules
    match /transactions/{txId} {
      allow read: if request.auth != null && resource.data.userUid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userUid == request.auth.uid;
      allow update, delete: if false; // Transactions are immutable
    }
  }
}
