# StellarNest — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Firebase Configuration
# Get these from: Firebase Console → Project Settings → Your Apps → Web App Config
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Stellar Network
# Set to "testnet" for hackathon demo, "public" for mainnet
VITE_STELLAR_NETWORK=testnet

# App Mode
# Set to "true" for mock mode (no real blockchain calls), "false" for live testnet
VITE_MOCK_MODE=false
